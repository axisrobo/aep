{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.axisrobo.com/harmovela-envelope.v0.2.schema.json",
  "title": "Harmovela Event Envelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["spec_version", "id", "type", "source", "created_at", "payload"],
  "properties": {
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "conversation_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "delivery": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "enum": ["best_effort", "at_least_once", "replayable"]
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "cursor": {
          "type": "string"
        }
      }
    },
    "payload_schema": {
      "type": "string",
      "format": "uri"
    },
    "belief_status": {
      "enum": ["asserted", "retracted", "revised", "contradicted", "unknown"]
    },
    "belief_scope": {
      "enum": ["fact", "inference", "observation", "preference", "hypothesis"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "stale_after": {
      "type": "string",
      "minLength": 1
    },
    "refresh_hint": {
      "type": "string",
      "format": "uri"
    },
    "delegated_by": {
      "type": "string"
    },
    "delegated_to": {
      "type": "string"
    },
    "parent_task_id": {
      "type": "string"
    },
    "handoff_token": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque bearer token proving ownership transfer from delegating agent to delegate. Issued on delegation.handoff.completed. Structured tokens encode issuer, delegate, task_id, parent_task_id, expiry, and nonce claims. See agent-runtime-semantics.md for validation requirements."
    },
    "checkpoint_id": {
      "type": "string"
    },
    "checkpoint_at": {
      "type": "string",
      "format": "date-time"
    },
    "interruption_policy": {
      "enum": ["save_and_stop", "drain_then_stop", "force_stop"]
    },
    "compensation_id": {
      "type": "string"
    },
    "evidence_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "id": { "type": "string" }
        },
        "required": ["source", "id"]
      }
    },
    "source_trust": {
      "enum": ["verified", "attested", "unverified", "signed"]
    },
    "attestation_count": {
      "type": "number",
      "minimum": 0
    },
    "data_provenance": {
      "type": "string",
      "format": "uri"
    },
    "payload": true
  }
}
