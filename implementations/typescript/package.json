{
  "name": "@axisrobo/aep",
  "version": "0.1.0-draft",
  "private": true,
  "type": "module",
    "workspaces": [
    "packages/event",
    "packages/governance",
    "packages/recovery",
    "packages/task",
    "packages/context",
    "packages/delegation",
    "packages/state",
    "packages/tool",
    "packages/agent",
    "packages/environment",
    "packages/adaptation",
    "packages/command",
    "packages/query",
    "packages/harness",
    "packages/runtime",
    "packages/cli",
    "packages/conformance",
    "packages/mcp-bridge"
  ],
  "description": "Harmovela Protocol TypeScript reference implementation.",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "harmovela-harness": "./src/stdio.js",
    "harmovela": "./packages/cli/src/harmovela.js",
    "harmovelad": "./packages/runtime/src/server.js"
  },
  "scripts": {
    "harmovela": "node ./packages/cli/src/harmovela.js",
    "harmovelad": "node ./packages/runtime/src/server.js",
    "harness": "node ./src/stdio.js",
    "demo:mcp-bridge": "node ./examples/mcp-bridge/demo.js",
    "demo:mcp-aep-consumer": "node ./examples/mcp-aep-consumer.js",
    "demo:async-tool": "node ./examples/async-tool-producer.js",
    "demo:production-e2e": "node ./examples/production-e2e.js",
    "test": "node --test",
    "conformance": "node ./packages/conformance/src/conformance-cli.js"
  },
  "dependencies": {
    "@axisrobo/harmovela-event": "file:packages/event",
    "@axisrobo/harmovela-governance": "file:packages/governance",
    "@axisrobo/harmovela-recovery": "file:packages/recovery",
    "@axisrobo/harmovela-task": "file:packages/task",
    "@axisrobo/harmovela-context": "file:packages/context",
    "@axisrobo/harmovela-delegation": "file:packages/delegation",
    "@axisrobo/harmovela-state": "file:packages/state",
    "@axisrobo/harmovela-tool": "file:packages/tool",
    "@axisrobo/harmovela-adaptation": "file:packages/adaptation",
    "@axisrobo/harmovela-command": "file:packages/command",
    "@axisrobo/harmovela-query": "file:packages/query",
    "@axisrobo/harmovela-agent": "file:packages/agent",
    "@axisrobo/harmovela-environment": "file:packages/environment",
    "@axisrobo/harmovela-harness": "file:packages/harness",
    "@axisrobo/harmovela-runtime": "file:packages/runtime",
    "@axisrobo/harmovela-cli": "file:packages/cli",
    "@axisrobo/harmovela-conformance": "file:packages/conformance",
    "@axisrobo/harmovela-mcp-bridge": "file:packages/mcp-bridge",
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^15.0.0",
    "pg": "^8.22.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "nats": "^2.29.3"
  }
}
